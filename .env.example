# Gmail (same app password as Home Assistant IMAP/SMTP)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_IMAP_FOLDER=[TEAMS-ALERT]
# After each sync: read (default), delete, or none
GMAIL_IMAP_AFTER_SYNC=read

# Local Docker Postgres (see docker-compose.yml)
DATABASE_URL=postgresql://teams:teams@localhost:5432/teams_alert_inbox

# Neon production: set DATABASE_URL to your Neon connection string
# DATABASE_SSL=true

# Optional: protect the app on Vercel (recommended)
APP_PASSWORD=
